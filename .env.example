# Azure OpenAI (via Azure AI Foundry)
# Required: Azure AI Foundry project endpoint (v2, Responses API)
AZURE_AI_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<your-project-id>
# Required: Model deployment name (e.g. gpt-4o, gpt-4.1)
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# Azure AI Search — Knowledge Base (Foundry IQ)
# Required: Search service endpoint
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
# Required: Search service API key
AZURE_SEARCH_API_KEY=<your-azure-search-api-key>
# Required: Knowledge base name (must contain a remote SharePoint knowledge source)
AZURE_SEARCH_KNOWLEDGE_BASE_NAME=<your-knowledge-base-name>

# Optional: KQL filter to limit SharePoint search scope
# Examples:
#   FileExtension:"docx" OR FileExtension:"pdf"
#   Path:"https://contoso.sharepoint.com/sites/hr/Shared Documents"
#   SiteID:"00aa00aa-bb11-cc22-dd33-44ee44ee44ee"
# AZURE_SEARCH_SHAREPOINT_FILTER=

# Maximum number of results (default: 10)
AZURE_SEARCH_TOP_K=10

# Workflow settings (optional)
DEEP_RESEARCH_MAX_ROUNDS=15
DEEP_RESEARCH_MAX_STALL=3
DEEP_RESEARCH_MAX_RESET=2
DEEP_RESEARCH_OUTPUT_DIR=./outputs
